🔷 STEP 5: Create Apex Class (Logic)

Go to:

Developer Console → New Apex Class
Class Name:

ResultController

Code:
public class ResultController {

    public static void calculate(List<Result__c> results) {

        for(Result__c r : results) {

            Decimal total =
                (r.DSBDA__c == null ? 0 : r.DSBDA__c) +
                (r.WT__c == null ? 0 : r.WT__c) +
                (r.AI__c == null ? 0 : r.AI__c) +
                (r.CC__c == null ? 0 : r.CC__c);

            Decimal percentage = total / 4;

            String grade;
            String status;

            if(percentage >= 75) {
                grade = 'A';
                status = 'Pass';
            }
            else if(percentage >= 60) {
                grade = 'B';
                status = 'Pass';
            }
            else if(percentage >= 50) {
                grade = 'C';
                status = 'Pass';
            }
            else if(percentage >= 35) {
                grade = 'D';
                status = 'Pass';
            }
            else {
                grade = 'Fail';
                status = 'Fail';
            }

            r.Total__c = total;
            r.Percentage__c = percentage;
            r.Grade__c = grade;
            r.Result_Status__c = status;
        }
    }
}

✔ Save

