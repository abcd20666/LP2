import java.util.*;

class MST {

    // Find function for Kruskal
    static int find(int parent[], int i) {

        while (parent[i] != i)
            i = parent[i];

        return i;
    }

    public static void main(String args[]) {

        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number of vertices:");
        int n = sc.nextInt();

        int graph[][] = new int[n][n];

        System.out.println("Enter adjacency matrix:");

        for (int i = 0; i < n; i++) {

            for (int j = 0; j < n; j++) {

                graph[i][j] = sc.nextInt();
            }
        }

        // ================= PRIM =================

        boolean visited[] = new boolean[n];

        visited[0] = true;

        int primCost = 0;

        System.out.println("\nMST using Prim's Algorithm:");

        for (int e = 0; e < n - 1; e++) {

            int min = 999, x = 0, y = 0;

            for (int i = 0; i < n; i++) {

                if (visited[i]) {

                    for (int j = 0; j < n; j++) {

                        if (!visited[j] && graph[i][j] != 0
                                && graph[i][j] < min) {

                            min = graph[i][j];
                            x = i;
                            y = j;
                        }
                    }
                }
            }

            System.out.println(x + " - " + y + " : " + min);

            primCost += min;

            visited[y] = true;
        }

        System.out.println("Total Cost = " + primCost);

        // ================= KRUSKAL =================

        int g[][] = new int[n][n];

        // Copy graph
        for (int i = 0; i < n; i++) {

            for (int j = 0; j < n; j++) {

                g[i][j] = graph[i][j];
            }
        }

        int parent[] = new int[n];

        for (int i = 0; i < n; i++)
            parent[i] = i;

        int kruskalCost = 0;

        System.out.println("\nMST using Kruskal's Algorithm:");

        for (int e = 0; e < n - 1;) {

            int min = 999, x = 0, y = 0;

            for (int i = 0; i < n; i++) {

                for (int j = 0; j < n; j++) {

                    if (g[i][j] != 0 && g[i][j] < min) {

                        min = g[i][j];
                        x = i;
                        y = j;
                    }
                }
            }

            int a = find(parent, x);

            int b = find(parent, y);

            if (a != b) {

                System.out.println(x + " - " + y + " : " + min);

                kruskalCost += min;

                parent[a] = b;

                e++;
            }

            g[x][y] = g[y][x] = 999;
        }

        System.out.println("Total Cost = " + kruskalCost);

        sc.close();
    }
}


