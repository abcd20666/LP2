import java.util.*;

class SelectionSort {

    public static void main(String args[]) {

        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number of elements:");

        int n = sc.nextInt();

        int a[] = new int[n];

        System.out.println("Enter elements:");

        for (int i = 0; i < n; i++) {

            a[i] = sc.nextInt();
        }

        // Print original array
        System.out.println("\nOriginal Array:");

        for (int x : a) {

            System.out.print(x + " ");
        }

        // Selection Sort
        for (int i = 0; i < n - 1; i++) {

            int min = i;

            for (int j = i + 1; j < n; j++) {

                if (a[j] < a[min]) {

                    min = j;
                }
            }

            // Swap
            int temp = a[i];
            a[i] = a[min];
            a[min] = temp;

            // Print each iteration
            System.out.println("\n\nIteration " + (i + 1) + ":");

            for (int k = 0; k < n; k++) {

                System.out.print(a[k] + " ");
            }
        }

        System.out.println("\n\nSorted Elements:");

        for (int x : a) {

            System.out.print(x + " ");
        }

        sc.close();
    }
}


